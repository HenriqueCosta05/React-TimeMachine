{
  "name": "@henriquecosta/react-debugmachine-player",
  "version": "1.0.0",
  "description": "Deterministic replay of a captured event log — re-applies DOM/state events in order against a live or headless instance of the app.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@henriquecosta/react-debugmachine-shared": "workspace:*"
  },
  "devDependencies": {
    "@henriquecosta/react-debugmachine-recorder": "workspace:*",
    "jsdom": "^29.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
