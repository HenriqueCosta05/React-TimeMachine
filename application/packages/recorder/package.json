{
  "name": "@react-time-machine/recorder",
  "version": "0.1.0",
  "description": "Captures state/props diffs, DOM mutations, and network activity into one ordered event log.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@react-time-machine/shared": "workspace:*"
  },
  "devDependencies": {
    "jsdom": "^29.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
